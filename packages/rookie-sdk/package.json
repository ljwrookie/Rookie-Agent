{
  "name": "@rookie/agent-sdk",
  "version": "0.1.0",
  "description": "Rookie Agent SDK - TypeScript orchestration layer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
